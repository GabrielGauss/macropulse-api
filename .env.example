# ══════════════════════════════════════════════════════════════
# MacroPulse – Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# ══════════════════════════════════════════════════════════════

# ── Deployment environment ────────────────────────────────────
# Controls startup guards: development | production
# In production, LS_WEBHOOK_SECRET must be set and CORS_ORIGINS must not be '*'
ENV=development

# ── General ──────────────────────────────────────────────────
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── FRED API (required) ──────────────────────────────────────
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Database ─────────────────────────────────────────────────
DB_HOST=timescaledb   # use "localhost" for local dev outside Docker
DB_PORT=5432
DB_USER=macropulse
DB_PASSWORD=change_me_in_production
DB_NAME=macropulse

# ── IRL Engine (MTA Signing) ─────────────────────────────────
# Ed25519 private key (hex, 32 bytes) for signing /regime/current responses.
# Generate key pair:
#   python -c "
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   k = Ed25519PrivateKey.generate()
#   print('PRIVATE:', k.private_bytes_raw().hex())
#   print('PUBLIC: ', k.public_key().public_bytes_raw().hex())
#   "
# Put PRIVATE here; put PUBLIC in irl-engine/.env as MACROPULSE_PUBKEY_HEX.
MTA_SIGNING_KEY_HEX=

# ── Auth ─────────────────────────────────────────────────────
# Empty list = dev-mode (no auth enforced).
# In production, leave empty — keys are managed in the DB.
API_KEYS=[]

# Master owner key — bypasses all tier gates and rate limiting.
# Generate with: python -c "import secrets; print('mp_' + secrets.token_urlsafe(32))"
# Never commit the real value. Keep in .env only.
OWNER_API_KEY=

# Owner email — used in API responses when the owner key is used.
OWNER_EMAIL=owner@macropulse.live

# ── CORS ─────────────────────────────────────────────────────
# Production: add your site domain
CORS_ORIGINS=["https://macropulse.live","https://www.macropulse.live","http://localhost:3000"]

# ── Rate limiting ────────────────────────────────────────────
# 0 = disabled globally (tier limits from DB apply per-key)
RATE_LIMIT_PER_DAY=0

# ── Model ────────────────────────────────────────────────────
DEFAULT_MODEL_VERSION=v2

# ── AI / Commentary ──────────────────────────────────────────
# Claude API key for AI commentary endpoint
# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Scheduler ────────────────────────────────────────────────
PIPELINE_CRON_HOUR=18    # 18:00 UTC = after US market close
PIPELINE_CRON_MINUTE=30

# ── Stripe Billing ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...          # Secret key (sk_live_... or sk_test_... for dev)
STRIPE_PUBLISHABLE_KEY=pk_live_...     # Publishable key (used for frontend Checkout redirect)
STRIPE_WEBHOOK_SECRET=whsec_...        # Endpoint signing secret — Stripe → Webhooks → endpoint

# MacroPulse subscription prices (create in Stripe → Products)
STRIPE_STARTER_PRICE_ID=price_...      # $49/mo recurring price ID
STRIPE_PRO_PRICE_ID=price_...          # $199/mo recurring price ID
STRIPE_STARTER_PRODUCT_ID=prod_...     # MacroPulse Starter product ID
STRIPE_PRO_PRODUCT_ID=prod_...         # MacroPulse Pro product ID
STRIPE_SUCCESS_URL=https://macropulse.live/welcome
STRIPE_CANCEL_URL=https://macropulse.live/pricing

# IRL Engine subscription prices
STRIPE_IRL_SIDECAR_PRICE_ID=price_...  # IRL Sidecar (L1) recurring price ID
STRIPE_IRL_SIDECAR_PRODUCT_ID=prod_... # IRL Sidecar product ID
STRIPE_IRL_AUDIT_PRICE_ID=price_...    # IRL Audit (L2) recurring price ID
STRIPE_IRL_AUDIT_PRODUCT_ID=prod_...   # IRL Audit product ID
STRIPE_IRL_WEBHOOK_SECRET=whsec_...    # Separate webhook secret for IRL endpoint (falls back to STRIPE_WEBHOOK_SECRET)
STRIPE_IRL_SUCCESS_URL=https://macropulse.live/irl-welcome
STRIPE_IRL_CANCEL_URL=https://macropulse.live/irl.html

# ── Alerting (optional) ──────────────────────────────────────
# Operator-level alerts (pipeline failures, drift warnings)
# Slack or Discord webhook URL
WEBHOOK_URL=

# Transactional email via Brevo (subscriber regime-change alerts)
# Get API key at: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
# Override sender address (must be a verified Brevo sender)
BREVO_SENDER_EMAIL=

# Discord channel webhook for daily macro signal posts
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Twitter/X integration for automated regime-change posts
# Create app at: https://developer.twitter.com → Projects & Apps
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Email alerts via SMTP (operator notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=[]

# Pipeline failure alert email (owner/ops inbox)
# If set, an email is sent when the daily pipeline fails or goes stale >26h
PIPELINE_ALERT_EMAIL=
