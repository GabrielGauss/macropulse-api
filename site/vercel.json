{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/dashboard", "destination": "https://api.macropulse.live/dashboard", "permanent": false },
    { "source": "/docs",      "destination": "/api-docs",                             "permanent": false }
  ],
  "rewrites": [
    { "source": "/pricing",  "destination": "/pricing.html" },
    { "source": "/api-docs", "destination": "/api-docs.html" },
    { "source": "/terms",    "destination": "/terms.html" },
    { "source": "/privacy",  "destination": "/privacy.html" },
    { "source": "/refund",   "destination": "/refund.html" },
    { "source": "/welcome",  "destination": "/welcome.html" },
    { "source": "/irl",      "destination": "/irl.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
